---
interface Props {
  productId?: string;
  name: string;
  description: string;
  applications: string[];
  href?: string;
  class?: string;
}

const {
  productId,
  name,
  description,
  href,
  class: className = "",
} = Astro.props;

const base =
  "catalog-card group bg-white border border-muted rounded-lg relative overflow-hidden flex flex-col hover:border-primary/40 hover:shadow-elevated transition-all duration-300";
---

{
  href ? (
    <a href={href} class={`${base} ${className}`}>
      <div
        class="absolute left-0 top-0 bottom-0 w-1 bg-primary rounded-l-lg z-10"
        aria-hidden="true"
      />

      {productId && (
        <div class="card-spring-preview w-full" aria-hidden="true">
          <div class="card-loader" data-card-loader>
            <span class="card-spinner"></span>
          </div>
          <canvas data-card-spring data-product-id={productId} />
        </div>
      )}

      <div class="p-6 flex flex-col flex-1">
        <h3 class="font-heading text-[0.875rem] font-bold uppercase tracking-wide text-foreground mb-3 group-hover:text-primary transition-colors duration-200">
          {name}
        </h3>

        <p class="text-[0.875rem] text-neutral leading-relaxed flex-1 mb-5">
          {description}
        </p>

        <span class="inline-flex items-center gap-1.5 text-[0.8125rem] font-heading font-bold uppercase tracking-wide text-primary group-hover:gap-2.5 transition-all duration-200">
          Ver ficha técnica
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <line x1="5" y1="12" x2="19" y2="12" />
            <polyline points="12 5 19 12 12 19" />
          </svg>
        </span>
      </div>
    </a>
  ) : (
    <article class={`${base} ${className}`}>
      <div
        class="absolute left-0 top-0 bottom-0 w-1 bg-primary rounded-l-lg z-10"
        aria-hidden="true"
      />

      {productId && (
        <div class="card-spring-preview w-full" aria-hidden="true">
          <div class="card-loader" data-card-loader>
            <span class="card-spinner"></span>
          </div>
          <canvas data-card-spring data-product-id={productId} />
        </div>
      )}

      <div class="p-6 flex flex-col flex-1">
        <h3 class="font-heading text-[0.875rem] font-bold uppercase tracking-wide text-foreground mb-3">
          {name}
        </h3>

        <p class="text-[0.875rem] text-neutral leading-relaxed flex-1">
          {description}
        </p>
      </div>
    </article>
  )
}

<style>
  .card-spring-preview {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    position: relative;
    background:
      radial-gradient(
        circle at 50% 40%,
        rgb(66 140 13 / 0.08),
        transparent 65%
      ),
      #f4f5f2;
  }

  .card-spring-preview canvas {
    width: 100%;
    height: 100%;
    display: block;
  }

  .card-loader {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    transition: opacity 0.3s ease;
  }

  .card-loader.hidden {
    opacity: 0;
    pointer-events: none;
  }

  .card-spinner {
    display: block;
    width: 1.5rem;
    height: 1.5rem;
    border: 2px solid rgba(66, 140, 13, 0.2);
    border-top-color: #428c0d;
    border-radius: 50%;
    animation: card-spin 0.7s linear infinite;
  }

  @keyframes card-spin {
    to { transform: rotate(360deg); }
  }
</style>

<script>
  import { createViewerBase, loadProductMesh } from "@/lib/spring-viewer";
  import * as THREE from "three";

  document
    .querySelectorAll<HTMLCanvasElement>("[data-card-spring]")
    .forEach((canvas) => {
      const productId = canvas.dataset.productId ?? "compresion";

      const { scene, camera, renderer, resize } =
        createViewerBase(canvas, {
          transparent: true,
          cameraZ: 9,
          fov: 40,
        });

      let mesh: THREE.Mesh | null = null;
      const loaderEl = canvas.previousElementSibling as HTMLElement | null;

      // lowDetail=true: reduces vertices ~75% for small card preview
      loadProductMesh(scene, productId, (loaded) => {
        mesh = loaded;
        mesh.rotation.x = Math.PI * 0.18;
        loaderEl?.classList.add('hidden');
      }, true);

      // ── RAF loop (start/stop controlled by IntersectionObserver) ──────────
      let rafId = 0;

      function startLoop() {
        if (rafId) return;
        function tick() {
          rafId = requestAnimationFrame(tick);
          if (document.hidden) return;
          if (mesh) mesh.rotation.y += 0.012;
          renderer.render(scene, camera);
        }
        rafId = requestAnimationFrame(tick);
      }

      function stopLoop() {
        cancelAnimationFrame(rafId);
        rafId = 0;
      }

      // ── ResizeObserver ─────────────────────────────────────────────────────
      const resizeObserver = new ResizeObserver(resize);
      resizeObserver.observe(canvas.parentElement!);

      // ── IntersectionObserver: pause render when off-screen ─────────────────
      const io = new IntersectionObserver(
        ([entry]) => (entry.isIntersecting ? startLoop() : stopLoop()),
        { threshold: 0 },
      );
      io.observe(canvas.parentElement!);

      // ── Cleanup on page unload ─────────────────────────────────────────────
      window.addEventListener(
        "pagehide",
        () => {
          stopLoop();
          resizeObserver.disconnect();
          io.disconnect();
          if (mesh) {
            mesh.geometry.dispose();
            (mesh.material as THREE.Material).dispose();
          }
          renderer.forceContextLoss();
          renderer.dispose();
        },
        { once: true },
      );

      resize();
    });
</script>
