---
interface Props {
  productId: string;
  label?: string;
  title?: string;
}

const { productId, label = "Visor 3D del resorte", title } = Astro.props;
---

<div class="spring-viewer-wrap">
  <!-- {title && <p class="viewer-title lg:hidden">{title}</p>} -->

  <div
    class="spring-product-viewer"
    data-product-viewer
    data-product-id={productId}
    role="img"
    aria-label={label}
  >
    <canvas></canvas>

    <!-- Loading indicator -->
    <div class="viewer-loading" aria-hidden="true">
      <span class="viewer-spinner"></span>
    </div>

    <!-- Touch gate: visible only on touch devices (pointer: coarse).
         Controls are locked until the user taps this overlay. -->
    <button
      class="viewer-touch-gate"
      aria-label="Activar visor 3D para rotar el modelo"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="28"
        height="28"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M18 11V6a2 2 0 0 0-2-2a2 2 0 0 0-2 2"></path>
        <path d="M14 10V4a2 2 0 0 0-2-2a2 2 0 0 0-2 2v2"></path>
        <path d="M10 10.5V6a2 2 0 0 0-2-2a2 2 0 0 0-2 2v8"></path>
        <path
          d="M18 11a2 2 0 1 1 4 0v3a8 8 0 0 1-8 8h-2c-2.8 0-4.5-.86-5.99-2.34l-3.6-3.6a2 2 0 0 1 2.83-2.82L7 15"
        ></path>
      </svg>
      <span>Mover / Zoom</span>
    </button>

    <p class="viewer-hint" aria-hidden="true">Arrastra y haz zoom</p>
  </div>
</div>

<style>
  .spring-viewer-wrap {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .viewer-title {
    font-family: var(--font-heading);
    font-size: 0.875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-foreground);
    line-height: 1.3;
  }

  .spring-product-viewer {
    width: 100%;
    aspect-ratio: 1 / 1;
    border-radius: 1.5rem;
    overflow: hidden;
    position: relative;
    background:
      radial-gradient(
        circle at 50% 35%,
        rgb(66 140 13 / 0.12),
        transparent 65%
      ),
      #0e160b;
    cursor: grab;
  }

  .spring-product-viewer:active {
    cursor: grabbing;
  }

  .spring-product-viewer canvas {
    width: 100%;
    height: 100%;
    display: block;
  }

  /* ── Touch gate overlay ───────────────────────────────── */
  .viewer-touch-gate {
    display: none;
    position: absolute;
    inset: 0;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.625rem;
    background: rgba(14, 22, 11, 0.55);
    backdrop-filter: blur(2px);
    border: none;
    cursor: pointer;
    color: #ffffff;
    transition: opacity 0.35s ease;
    z-index: 10;
  }

  .viewer-touch-gate span {
    font-family: var(--font-heading);
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.8);
  }

  .viewer-touch-gate::before {
    content: "";
    position: absolute;
    width: 4rem;
    height: 4rem;
    border-radius: 50%;
    border: 1.5px solid rgba(66, 140, 13, 0.6);
    animation: gate-pulse 1.8s ease-out infinite;
  }

  @keyframes gate-pulse {
    0% {
      transform: scale(0.85);
      opacity: 0.8;
    }
    100% {
      transform: scale(1.55);
      opacity: 0;
    }
  }

  @media (pointer: coarse) {
    .viewer-touch-gate {
      display: flex;
    }
  }

  .viewer-touch-gate.dismissed {
    opacity: 0;
    pointer-events: none;
  }

  /* ── Drag hint ────────────────────────────────────────── */
  .viewer-hint {
    position: absolute;
    bottom: 1.25rem;
    left: 50%;
    transform: translateX(-50%);
    white-space: nowrap;
    font-size: 0.6875rem;
    font-family: var(--font-heading);
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.3);
    pointer-events: none;
    user-select: none;
    transition: opacity 0.4s ease;
  }

  .viewer-hint.hidden {
    opacity: 0;
  }

  /* ── Loading indicator ───────────────────────────────── */
  .viewer-loading {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 5;
    transition: opacity 0.4s ease;
  }

  .viewer-loading.hidden {
    opacity: 0;
    pointer-events: none;
  }

  .viewer-spinner {
    display: block;
    width: 2rem;
    height: 2rem;
    border: 2px solid rgba(66, 140, 13, 0.25);
    border-top-color: #428c0d;
    border-radius: 50%;
    animation: viewer-spin 0.8s linear infinite;
  }

  @keyframes viewer-spin {
    to {
      transform: rotate(360deg);
    }
  }
</style>

<script>
  import * as THREE from "three";
  import { createViewerBase, loadProductMesh } from "@/lib/spring-viewer";
  import { OrbitControls } from "three/examples/jsm/controls/OrbitControls.js";

  document
    .querySelectorAll<HTMLElement>("[data-product-viewer]")
    .forEach((container) => {
      const canvas = container.querySelector<HTMLCanvasElement>("canvas");
      const hintEl = container.querySelector<HTMLElement>(".viewer-hint");
      const touchGate =
        container.querySelector<HTMLButtonElement>(".viewer-touch-gate");
      const productId = container.dataset.productId ?? "compresion";

      if (!canvas) return;

      const { scene, camera, renderer, resize } = createViewerBase(canvas, {
        transparent: false,
        cameraZ: 7,
        fov: 40,
      });

      // ── OrbitControls ──────────────────────────────────────
      const controls = new OrbitControls(camera, canvas);
      controls.enableDamping = true;
      controls.dampingFactor = 0.06;
      controls.autoRotate = true;
      controls.autoRotateSpeed = 1.5;
      controls.enableZoom = true;
      controls.enablePan = false;
      controls.zoomSpeed = 0.9;
      controls.minDistance = 5.5;
      controls.maxDistance = 16;
      controls.minPolarAngle = Math.PI * 0.2;
      controls.maxPolarAngle = Math.PI * 0.8;

      // ── Touch gate ─────────────────────────────────────────
      const isTouchDevice = window.matchMedia("(pointer: coarse)").matches;
      if (isTouchDevice) {
        controls.enabled = false;
        canvas.style.touchAction = "auto";

        touchGate?.addEventListener(
          "click",
          () => {
            controls.enabled = true;
            canvas.style.touchAction = "none";
            touchGate.classList.add("dismissed");
            hintEl?.classList.remove("hidden");
          },
          { once: true },
        );
      }

      // Hide drag hint on first interaction
      let hintHidden = false;
      controls.addEventListener("start", () => {
        if (!hintHidden && hintEl) {
          hintHidden = true;
          hintEl.classList.add("hidden");
        }
      });

      // ── Load mesh ──────────────────────────────────────────
      const loadingEl = container.querySelector<HTMLElement>(".viewer-loading");
      let mesh: THREE.Mesh | null = null;
      loadProductMesh(scene, productId, (loaded) => {
        mesh = loaded;
        loadingEl?.classList.add("hidden");
      });

      // ── Conditional controls.update ────────────────────────
      let userInteracting = false;
      controls.addEventListener("start", () => {
        userInteracting = true;
      });
      controls.addEventListener("end", () => {
        userInteracting = false;
      });

      // ── RAF loop (start/stop via IntersectionObserver) ─────
      let rafId = 0;

      function startLoop() {
        if (rafId) return;
        function tick() {
          rafId = requestAnimationFrame(tick);
          if (document.hidden) return;
          if (controls.autoRotate || userInteracting) controls.update();
          renderer.render(scene, camera);
        }
        rafId = requestAnimationFrame(tick);
      }

      function stopLoop() {
        cancelAnimationFrame(rafId);
        rafId = 0;
      }

      // ── ResizeObserver ─────────────────────────────────────
      const resizeObserver = new ResizeObserver(resize);
      resizeObserver.observe(container);

      // ── IntersectionObserver: pause when off-screen ────────
      const io = new IntersectionObserver(
        ([entry]) => (entry.isIntersecting ? startLoop() : stopLoop()),
        { threshold: 0 },
      );
      io.observe(container);

      // ── Cleanup on page unload ─────────────────────────────
      window.addEventListener(
        "pagehide",
        () => {
          stopLoop();
          resizeObserver.disconnect();
          io.disconnect();
          controls.dispose();
          if (mesh) {
            mesh.geometry.dispose();
            (mesh.material as THREE.Material).dispose();
          }
          renderer.forceContextLoss();
          renderer.dispose();
        },
        { once: true },
      );

      resize();
    });
</script>
