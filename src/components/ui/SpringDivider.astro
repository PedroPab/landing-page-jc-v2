---
interface Props {
  class?: string;
  width?: number;
  height?: number;
  coils?: number;
  strokeWidth?: number;
}

const {
  class: className = "",
  width = 180,
  height = 34,
  coils = 10,
  strokeWidth = 2,
} = Astro.props;

const padding = 8;
const springStart = padding + 14;
const springEnd = width - padding - 14;
const springWidth = springEnd - springStart;
const coilWidth = springWidth / coils;
const centerY = height / 2;
const radiusY = height * 0.34;

const path: string[] = [];

// extremo izquierdo
path.push(`M ${padding} ${centerY}`);
path.push(`L ${springStart} ${centerY}`);

// cuerpo del resorte
for (let i = 0; i < coils; i++) {
  const x = springStart + i * coilWidth;
  const xMid = x + coilWidth / 2;
  const xEnd = x + coilWidth;

  path.push(`
    C ${x + coilWidth * 0.15} ${centerY - radiusY},
      ${xMid - coilWidth * 0.15} ${centerY - radiusY},
      ${xMid} ${centerY}
  `);

  path.push(`
    C ${xMid + coilWidth * 0.15} ${centerY + radiusY},
      ${xEnd - coilWidth * 0.15} ${centerY + radiusY},
      ${xEnd} ${centerY}
  `);
}

// extremo derecho
path.push(`L ${width - padding} ${centerY}`);

const d = path.join(" ");
---

<svg
  class={`text-primary ${className}`}
  width={width}
  height={height}
  viewBox={`0 0 ${width} ${height}`}
  fill="none"
  aria-hidden="true"
  role="presentation"
>
  <path
    d={d}
    stroke="currentColor"
    stroke-width={strokeWidth}
    stroke-linecap="round"
    stroke-linejoin="round"></path>

  <path
    d={d}
    stroke="currentColor"
    stroke-width={strokeWidth * 0.45}
    stroke-linecap="round"
    stroke-linejoin="round"
    opacity="0.35"
    transform={`translate(0 ${strokeWidth * 1.4})`}></path>
</svg>
