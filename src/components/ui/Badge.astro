---
interface Props {
  variant?: 'default' | 'primary' | 'muted' | 'white';
  class?: string;
}

const { variant = 'default', class: className = '' } = Astro.props;

const variants: Record<string, string> = {
  default: 'bg-surface text-foreground border border-muted',
  primary: 'bg-primary/10 text-primary border border-primary/20',
  muted:   'bg-muted/30 text-neutral border border-muted',
  white:   'bg-white/10 text-white border border-white/20',
};
---

<span
  class={`inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-[0.75rem] font-medium leading-none ${variants[variant] ?? variants.default} ${className}`}
>
  <slot />
</span>
