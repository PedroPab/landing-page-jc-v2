---
interface Props {
  href?: string;
  variant?: 'primary' | 'outline' | 'ghost' | 'whatsapp' | 'outline-white';
  size?: 'sm' | 'md' | 'lg';
  external?: boolean;
  type?: 'button' | 'submit' | 'reset';
  class?: string;
  [key: string]: unknown;
}

const {
  href,
  variant = 'primary',
  size = 'md',
  external = false,
  type = 'button',
  class: className = '',
  ...attrs
} = Astro.props;

const base =
  'inline-flex items-center justify-center gap-2 font-heading font-bold uppercase tracking-wide transition-colors duration-150 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 disabled:opacity-50 cursor-pointer rounded-md whitespace-nowrap';

const variants: Record<string, string> = {
  primary:       'bg-primary text-white hover:bg-[#357a0a] active:scale-[0.98]',
  outline:       'border-2 border-primary text-primary hover:bg-primary hover:text-white',
  ghost:         'text-primary hover:bg-surface',
  whatsapp:      'bg-[#25D366] text-white hover:bg-[#1ebe5d] active:scale-[0.98]',
  'outline-white': 'border-2 border-white text-white hover:bg-white hover:text-primary',
};

const sizes: Record<string, string> = {
  sm: 'px-4 py-2 text-xs',
  md: 'px-6 py-3 text-sm',
  lg: 'px-8 py-4 text-base',
};

const classes = [base, variants[variant] ?? variants.primary, sizes[size], className]
  .filter(Boolean)
  .join(' ');

const linkAttrs = href && external ? { target: '_blank', rel: 'noopener noreferrer' } : {};
---

{href ? (
  <a href={href} class={classes} {...linkAttrs} {...attrs}>
    <slot />
  </a>
) : (
  <button type={type} class={classes} {...attrs}>
    <slot />
  </button>
)}
