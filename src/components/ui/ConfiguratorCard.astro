---
interface Props {
  href?: string;
  class?: string;
}
const { href = '/configurar', class: className = '' } = Astro.props;
---

<a
  href={href}
  class={`configurator-card group ${className}`}
  aria-label="Crea tu resorte personalizado"
>
  <!-- Animated spring coil illustration -->
  <div class="card-illustration" aria-hidden="true">
    <svg viewBox="0 0 60 80" fill="none" xmlns="http://www.w3.org/2000/svg" class="spring-icon">
      <path d="M10 8 C30 8, 50 16, 50 24 C50 32, 10 32, 10 40 C10 48, 50 48, 50 56 C50 64, 10 64, 10 72"
            stroke="currentColor" stroke-width="3.5" stroke-linecap="round" fill="none"/>
    </svg>
  </div>

  <div class="card-body">
    <span class="card-badge">Personalizado</span>

    <h3 class="card-title">Crea tu<br/>Resorte</h3>

    <p class="card-desc">
      Define los parámetros, visualiza en 3D en tiempo real y descarga tu modelo STL.
    </p>

    <span class="card-cta">
      Configurar ahora
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
           fill="none" stroke="currentColor" stroke-width="2.5"
           stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="5" y1="12" x2="19" y2="12"/>
        <polyline points="12 5 19 12 12 19"/>
      </svg>
    </span>
  </div>
</a>

<style>
  .configurator-card {
    display: flex;
    flex-direction: column;
    position: relative;
    overflow: hidden;
    border-radius: 0.5rem;
    background: var(--color-foreground);
    border: 1px solid rgba(66, 140, 13, 0.25);
    padding: 2rem;
    gap: 1.5rem;
    text-decoration: none;
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .configurator-card:hover {
    border-color: rgba(66, 140, 13, 0.7);
    box-shadow: 0 0 0 1px rgba(66, 140, 13, 0.25), 0 8px 32px rgba(0,0,0,0.4);
  }

  /* Top green accent line */
  .configurator-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, #428c0d, #76a646, #428c0d);
    background-size: 200% 100%;
    animation: shimmer 3s linear infinite;
  }

  @keyframes shimmer {
    0%   { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }

  /* Spring illustration */
  .card-illustration {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .spring-icon {
    width: 3rem;
    height: 4rem;
    color: #428c0d;
    filter: drop-shadow(0 0 8px rgba(66, 140, 13, 0.5));
    animation: spring-bounce 2.4s ease-in-out infinite;
  }

  @keyframes spring-bounce {
    0%, 100% { transform: scaleY(1); }
    40%       { transform: scaleY(0.72); }
    60%       { transform: scaleY(1.12); }
  }

  /* Body */
  .card-body {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    flex: 1;
  }

  .card-badge {
    display: inline-block;
    font-family: var(--font-heading);
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #428c0d;
    background: rgba(66, 140, 13, 0.12);
    border: 1px solid rgba(66, 140, 13, 0.25);
    border-radius: 2rem;
    padding: 0.2rem 0.65rem;
    width: fit-content;
  }

  .card-title {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 800;
    text-transform: uppercase;
    line-height: 1.1;
    color: #ffffff;
    letter-spacing: -0.01em;
  }

  .card-desc {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.55);
    line-height: 1.6;
    flex: 1;
  }

  .card-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-heading);
    font-size: 0.8125rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #428c0d;
    transition: gap 0.2s ease;
    margin-top: 0.25rem;
  }

  .configurator-card:hover .card-cta {
    gap: 0.75rem;
  }
</style>
