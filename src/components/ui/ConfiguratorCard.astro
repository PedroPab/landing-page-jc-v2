---
interface Props {
  href?: string;
  class?: string;
}
const { href = '/configurar', class: className = '' } = Astro.props;
---

<a
  href={href}
  class={`configurator-card group sm:col-span-2 ${className}`}
  aria-label="Crea tu resorte personalizado"
>
  <!-- Animated spring coil illustration -->
  <div class="card-illustration" aria-hidden="true">
    <svg viewBox="0 0 60 80" fill="none" xmlns="http://www.w3.org/2000/svg" class="spring-icon">
      <path d="M10 8 C30 8, 50 16, 50 24 C50 32, 10 32, 10 40 C10 48, 50 48, 50 56 C50 64, 10 64, 10 72"
            stroke="currentColor" stroke-width="3.5" stroke-linecap="round" fill="none"/>
    </svg>
  </div>

  <div class="card-body">
    <span class="card-badge">Configurador 3D</span>

    <h3 class="card-title">Crea Tu Resorte<br/>A La Medida</h3>

    <p class="card-desc">
      Define los parámetros, visualiza en 3D en tiempo real y descarga tu modelo STL.
    </p>

    <ul class="card-points" aria-hidden="true">
      <li>Visualización inmediata</li>
      <li>Ajuste técnico por medidas</li>
      <li>Exportación STL</li>
    </ul>

    <span class="card-cta">
      Configurar ahora
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
           fill="none" stroke="currentColor" stroke-width="2.5"
           stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="5" y1="12" x2="19" y2="12"/>
        <polyline points="12 5 19 12 12 19"/>
      </svg>
    </span>
  </div>
</a>

<style>
  .configurator-card {
    display: grid;
    grid-template-columns: 1fr;
    position: relative;
    overflow: hidden;
    border-radius: 1rem;
    background:
      radial-gradient(circle at top right, rgba(118, 166, 70, 0.2), transparent 32%),
      radial-gradient(circle at bottom left, rgba(66, 140, 13, 0.16), transparent 28%),
      linear-gradient(135deg, #0f180c 0%, #152111 55%, #0d130b 100%);
    border: 1px solid rgba(66, 140, 13, 0.3);
    padding: 2rem;
    gap: 1.75rem;
    text-decoration: none;
    min-height: 100%;
    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .configurator-card:hover {
    border-color: rgba(66, 140, 13, 0.7);
    box-shadow: 0 0 0 1px rgba(66, 140, 13, 0.25), 0 18px 42px rgba(0,0,0,0.38);
    transform: translateY(-2px);
  }

  /* Top green accent line */
  .configurator-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, #428c0d, #76a646, #428c0d);
    background-size: 200% 100%;
    animation: shimmer 3s linear infinite;
  }

  .configurator-card::after {
    content: '';
    position: absolute;
    inset: auto -10% -35% auto;
    width: 16rem;
    height: 16rem;
    border-radius: 999px;
    background: radial-gradient(circle, rgba(66, 140, 13, 0.18) 0%, transparent 68%);
    pointer-events: none;
  }

  @keyframes shimmer {
    0%   { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }

  /* Spring illustration */
  .card-illustration {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 10rem;
    border-radius: 0.875rem;
    background: linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.01));
    border: 1px solid rgba(255, 255, 255, 0.06);
  }

  .spring-icon {
    width: 5.5rem;
    height: 7rem;
    color: #428c0d;
    filter: drop-shadow(0 0 12px rgba(66, 140, 13, 0.45));
    animation: spring-bounce 2.4s ease-in-out infinite;
  }

  @keyframes spring-bounce {
    0%, 100% { transform: scaleY(1); }
    40%       { transform: scaleY(0.72); }
    60%       { transform: scaleY(1.12); }
  }

  /* Body */
  .card-body {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    flex: 1;
    position: relative;
    z-index: 1;
  }

  .card-badge {
    display: inline-block;
    font-family: var(--font-heading);
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #d4efba;
    background: rgba(66, 140, 13, 0.18);
    border: 1px solid rgba(66, 140, 13, 0.35);
    border-radius: 2rem;
    padding: 0.2rem 0.65rem;
    width: fit-content;
  }

  .card-title {
    font-family: var(--font-heading);
    font-size: clamp(1.8rem, 3vw, 2.7rem);
    font-weight: 800;
    text-transform: uppercase;
    line-height: 0.98;
    color: #ffffff;
    letter-spacing: -0.03em;
    max-width: 12ch;
  }

  .card-desc {
    font-size: 0.95rem;
    color: rgba(255, 255, 255, 0.68);
    line-height: 1.6;
    max-width: 46ch;
  }

  .card-points {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    padding: 0;
    margin: 0.1rem 0 0;
    list-style: none;
  }

  .card-points li {
    font-family: var(--font-heading);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.72);
    padding: 0.45rem 0.7rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  .card-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-family: var(--font-heading);
    font-size: 0.875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #ffffff;
    width: fit-content;
    margin-top: auto;
    padding: 0.9rem 1.15rem;
    border-radius: 999px;
    background: linear-gradient(90deg, #428c0d, #5aab1b);
    box-shadow: 0 10px 24px rgba(66, 140, 13, 0.28);
    transition: gap 0.2s ease;
  }

  .configurator-card:hover .card-cta {
    gap: 0.85rem;
  }

  @media (min-width: 768px) {
    .configurator-card {
      grid-template-columns: minmax(11rem, 15rem) 1fr;
      align-items: center;
      padding: 2.25rem;
    }

    .card-illustration {
      min-height: 100%;
    }
  }
</style>
