---
import SectionHeading from '@/components/ui/SectionHeading.astro';
import SpringDivider from '@/components/ui/SpringDivider.astro';

interface DifferentialItem {
  title: string;
  description: string;
  icon?: string;
}

interface DifferentialsData {
  title: string;
  items: DifferentialItem[];
}

interface Props {
  data: DifferentialsData;
}

const { data } = Astro.props;

const icons: Record<string, string> = {
  star:      `<polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>`,
  ruler:     `<line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>`,
  refresh:   `<polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/>`,
  lightbulb: `<line x1="9" y1="21" x2="15" y2="21"/><line x1="12" y1="17" x2="12" y2="3"/><path d="M12 17a5 5 0 0 0 5-5c0-2.76-2.24-5-5-5S7 9.24 7 12a5 5 0 0 0 5 5z"/>`,
  home:      `<path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>`,
  shield:    `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>`,
  target:    `<circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/>`,
};
---

<section id="diferenciales" class="section-pad bg-depth-foreground text-white">
  <div class="container-jc">

    <SectionHeading
      eyebrow="Por qué elegirnos"
      title={data.title}
      light
    />

    <div class="flex mt-5 mb-10">
      <SpringDivider width={80} coils={6} class="opacity-60 animate-float-slow" />
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {data.items.map((item) => (
        <article class="flex gap-4 group">
          <!-- Icon -->
          {item.icon && icons[item.icon] && (
            <div class="shrink-0 mt-0.5 w-8 h-8 rounded flex items-center justify-center bg-primary/20">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="text-primary-soft"
                aria-hidden="true"
                set:html={icons[item.icon]}
              />
            </div>
          )}
          <!-- Text -->
          <div class="flex flex-col gap-1.5">
            <h3 class="font-heading text-[0.8125rem] font-bold uppercase tracking-wide text-white">
              {item.title}
            </h3>
            <p class="text-[0.8125rem] text-white/60 leading-relaxed">
              {item.description}
            </p>
          </div>
        </article>
      ))}
    </div>

  </div>
</section>
