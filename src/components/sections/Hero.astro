---
import Button from '@/components/ui/Button.astro';
import Badge from '@/components/ui/Badge.astro';
import SpringDivider from '@/components/ui/SpringDivider.astro';
import SectionMedia from '@/components/ui/SectionMedia.astro';

type MediaItem = {
  type: 'image' | 'video' | 'gif';
  src: string;
  alt: string;
  poster?: string;
  caption?: string;
  priority?: boolean;
};

interface HeroData {
  eyebrow: string;
  title: string;
  subtitle: string;
  supportingText?: string;
  badges: string[];
  primaryCta: { label: string; href: string };
  secondaryCta: { label: string; href: string };
  media?: MediaItem | null;
}

interface Props {
  data: HeroData;
  whatsappUrl: string;
}

const { data, whatsappUrl } = Astro.props;

const primaryHref = data.primaryCta.href === '#contacto' ? whatsappUrl : data.primaryCta.href;
const primaryExternal = primaryHref.startsWith('https://wa.me');
const hasMedia = data.media != null;
---

<section class="relative bg-foreground text-white overflow-hidden">
  <!-- Decorative spring pattern background -->
  <div class="absolute inset-0 spring-bg opacity-[0.04] pointer-events-none" aria-hidden="true"></div>
  <!-- Top border accent -->
  <div class="absolute top-0 left-0 right-0 h-1 bg-primary" aria-hidden="true"></div>

  <div class="container-jc relative z-10 py-16 lg:py-24">
    <div class={`grid ${hasMedia ? 'lg:grid-cols-2 gap-10 lg:gap-16' : ''} items-center`}>

      <!-- Text column -->
      <div class="flex flex-col max-w-3xl">

        <p class="font-heading text-primary-soft text-[0.75rem] font-bold uppercase tracking-widest mb-5">
          {data.eyebrow}
        </p>

        <h1 class="font-heading text-h1 font-bold uppercase leading-tight text-white mb-5">
          {data.title}
        </h1>

        <SpringDivider width={80} coils={6} class="mb-5" />

        <p class="text-subtitle text-white/80 leading-relaxed mb-4 max-w-xl">
          {data.subtitle}
        </p>

        {data.supportingText && (
          <p class="text-body text-white/60 leading-relaxed mb-8 max-w-lg">
            {data.supportingText}
          </p>
        )}

        <!-- Trust badges -->
        <ul class="flex flex-wrap gap-2 mb-8" aria-label="Puntos de confianza">
          {data.badges.map((badge) => (
            <li class="contents"><Badge variant="white">{badge}</Badge></li>
          ))}
        </ul>

        <!-- CTAs -->
        <div class="flex flex-wrap gap-4">
          <Button href={primaryHref} variant="whatsapp" size="lg" external={primaryExternal}>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            {data.primaryCta.label}
          </Button>
          <Button href={data.secondaryCta.href} variant="outline-white" size="lg">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
            {data.secondaryCta.label}
          </Button>
        </div>

      </div>

      <!-- Media column (desktop only when media present, mobile hidden) -->
      {hasMedia && (
        <div class="hidden lg:block">
          <!-- Accent border left -->
          <div class="relative pl-4 border-l-2 border-primary/30">
            <SectionMedia
              media={data.media}
              aspect="video"
              label="Foto del taller"
              class="rounded-lg overflow-hidden shadow-elevated ring-1 ring-white/10"
            />
          </div>
        </div>
      )}

      <!-- Mobile media strip (only when media is a real image — shown below text) -->
      {hasMedia && data.media?.type === 'image' && (
        <div class="lg:hidden mt-8">
          <SectionMedia
            media={data.media}
            aspect="video"
            label="Foto del taller"
            class="rounded-lg overflow-hidden shadow-card opacity-80"
          />
        </div>
      )}

    </div>
  </div>

  <div class="absolute bottom-0 left-0 right-0 h-px bg-white/10" aria-hidden="true"></div>
</section>
