---
interface SettingsData {
  name: string;
  tagline: string;
  nav: Array<{ label: string; href: string }>;
  address: { street: string; city: string; country: string; mapsUrl: string };
  whatsapp: { number: string; defaultMessage: string };
}

interface Props {
  settings: SettingsData;
  whatsappUrl: string;
}

const { settings, whatsappUrl } = Astro.props;
const currentYear = new Date().getFullYear();
---

<footer class="bg-foreground text-white" role="contentinfo">
  <!-- Main footer grid -->
  <div class="container-jc pt-14 pb-8">
    <div
      class="grid sm:grid-cols-2 lg:grid-cols-3 gap-10 pb-10 border-b border-white/10"
    >
      <!-- Brand column -->
      <div class="flex flex-col gap-4">
        <!-- Logo mark -->
        <a
          href="/"
          class="flex items-center gap-2 group w-fit"
          aria-label={`${settings.name} — Inicio`}
        >
          <img
            src="/favicon.svg"
            alt=""
            class="w-8 h-8 shrink-0"
            aria-hidden="true"
          />
          <span
            class="font-heading font-bold text-white text-sm uppercase tracking-wide group-hover:text-primary-soft transition-colors"
          >
            {settings.name}
          </span>
        </a>
        <!-- Tagline -->
        <p class="text-[0.8125rem] text-white/50 leading-relaxed max-w-[220px]">
          {settings.tagline}
        </p>
        <!-- Spring accent -->
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 60 8"
          width="60"
          height="8"
          fill="none"
          stroke="white"
          stroke-width="1.2"
          stroke-linecap="round"
          class="opacity-20 mt-1"
          aria-hidden="true"
        >
          <path
            d="M0 4 C3.75 0, 7.5 8, 11.25 4 C15 0, 18.75 8, 22.5 4 C26.25 0, 30 8, 33.75 4 C37.5 0, 41.25 8, 45 4 C48.75 0, 52.5 8, 56.25 4 C58 2, 59.5 4, 60 4"
          ></path>
        </svg>
        <!-- Location -->
        <address
          class="not-italic flex flex-col gap-1 text-[0.8125rem] text-white/40"
        >
          <span>{settings.address.city}</span>
          <span>{settings.address.country}</span>
        </address>
      </div>

      <!-- Navigation column -->
      <nav
        class="flex flex-col gap-2"
        aria-label="Navegación del pie de página"
      >
        <h3
          class="font-heading text-[0.7rem] uppercase tracking-widest text-white/30 font-bold mb-2"
        >
          Navegación
        </h3>
        {
          settings.nav.map((item) => (
            <a
              href={item.href}
              class="text-[0.8125rem] text-white/60 hover:text-white transition-colors w-fit"
            >
              {item.label}
            </a>
          ))
        }
      </nav>

      <!-- Contact column -->
      <div class="flex flex-col gap-4">
        <h3
          class="font-heading text-[0.7rem] uppercase tracking-widest text-white/30 font-bold"
        >
          Contacto
        </h3>

        <!-- WhatsApp link -->
        <a
          href={whatsappUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-[0.8125rem] text-white/60 hover:text-[#25D366] transition-colors w-fit"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            width="14"
            height="14"
            fill="currentColor"
            aria-hidden="true"
          >
            <path
              d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
            ></path>
          </svg>
          Escribir por WhatsApp
        </a>

        <!-- Maps link -->
        <a
          href={settings.address.mapsUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-[0.8125rem] text-white/60 hover:text-white transition-colors w-fit"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
            <circle cx="12" cy="10" r="3"></circle>
          </svg>
          {settings.address.city}
        </a>
      </div>
    </div>

    <!-- Copyright bar -->
    <div
      class="pt-6 flex flex-col sm:flex-row items-center justify-between gap-3 text-[0.7rem] text-white/30"
    >
      <p>
        &copy; {currentYear}
        {settings.name}. Todos los derechos reservados.
      </p>
      <p class="font-heading uppercase tracking-wide text-[0.65rem]">
        Medellín, Colombia
      </p>
    </div>
  </div>
</footer>
