---
import { render, type CollectionEntry } from 'astro:content';
import SectionHeading from '@/components/ui/SectionHeading.astro';
import Badge from '@/components/ui/Badge.astro';
import SpringDivider from '@/components/ui/SpringDivider.astro';
import SectionMedia from '@/components/ui/SectionMedia.astro';
import GalleryStrip from '@/components/ui/GalleryStrip.astro';

interface Props {
  entry: CollectionEntry<'caseStudies'>;
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, client, industry, summary, challenge, result, tags, image, gallery } = entry.data;
---

<section id="caso" class="section-pad bg-white">
  <div class="container-jc">

    <!-- Hero image (full-width, above content) -->
    {image && (
      <div class="mb-10 rounded-lg overflow-hidden shadow-card">
        <SectionMedia
          media={image}
          aspect="video"
          label="Imagen del caso"
          class="w-full"
        />
      </div>
    )}

    <!-- Header -->
    <div class="max-w-2xl mb-10">
      <SectionHeading
        eyebrow="Caso destacado"
        title={title}
        subtitle={summary}
      />
      <SpringDivider width={80} coils={6} class="mt-5" />
    </div>

    <!-- Content layout -->
    <div class="grid lg:grid-cols-5 gap-10 lg:gap-16 items-start">

      <!-- Sidebar (2 cols) -->
      <aside class="lg:col-span-2 flex flex-col gap-5">

        <div class="flex flex-wrap gap-2">
          <Badge variant="primary">{industry}</Badge>
          {client !== 'Sector minero' && <Badge variant="muted">{client}</Badge>}
        </div>

        <div class="flex flex-wrap gap-2">
          {tags.map((tag) => (
            <Badge variant="muted">{tag}</Badge>
          ))}
        </div>

        <!-- Challenge block -->
        <div class="bg-surface border border-muted rounded-lg p-5">
          <h3 class="font-heading text-[0.75rem] uppercase tracking-widest text-neutral font-bold mb-3">
            El reto
          </h3>
          <p class="text-[0.875rem] text-neutral leading-relaxed">
            {challenge}
          </p>
        </div>

        <!-- Result callout -->
        <div class="bg-primary/8 border border-primary/20 rounded-lg p-5">
          <h3 class="font-heading text-[0.75rem] uppercase tracking-widest text-primary font-bold mb-3">
            El resultado
          </h3>
          <p class="text-[0.875rem] text-foreground leading-relaxed">
            {result}
          </p>
        </div>

      </aside>

      <!-- Main content (3 cols) -->
      <div class="lg:col-span-3 flex flex-col gap-8">
        <article class="prose-jc">
          <Content />
        </article>

        <!-- Process gallery below MDX content -->
        {gallery && (
          <div>
            <h3 class="font-heading text-[0.75rem] uppercase tracking-widest text-neutral font-bold mb-4">
              Proceso y resultado
            </h3>
            <GalleryStrip
              items={gallery.items}
              layout={gallery.layout ?? 'featured'}
            />
          </div>
        )}
      </div>

    </div>

  </div>
</section>
