---
import { render, type CollectionEntry } from "astro:content";
import SectionHeading from "@/components/ui/SectionHeading.astro";
import SpringDivider from "@/components/ui/SpringDivider.astro";
import SectionMedia from "@/components/ui/SectionMedia.astro";

interface Props {
  story: CollectionEntry<"stories">;
}

const { story } = Astro.props;
const { Content } = await render(story);
---

<section id="historia" class="section-pad bg-surface">
  <div class="container-jc">
    <div class="max-w-3xl mx-auto">
      <SectionHeading
        eyebrow={story.data.sectionTitle}
        title={story.data.title}
        subtitle={story.data.subtitle}
        align="center"
      />

      <div class="flex justify-center mt-5 mb-10">
        <SpringDivider width={120} coils={8} />
      </div>
    </div>

    <!-- Two-column layout when media is provided -->
    <div
      class={`${story.data.media ? "grid lg:grid-cols-3 gap-10 lg:gap-16 items-start" : "max-w-3xl mx-auto"}`}
    >
      <!-- Prose content -->
      <article class={`prose-jc ${story.data.media ? "lg:col-span-2" : ""}`}>
        <Content />
      </article>

      <!-- Media column -->
      {
        story.data.media && (
          <aside>
            <SectionMedia
              media={story.data.media}
              aspect="portrait"
              label="Foto de la historia"
              class="rounded-lg overflow-hidden shadow-card sticky top-20"
            />
          </aside>
        )
      }
    </div>
  </div>
</section>
