---
import Button from '@/components/ui/Button.astro';

type MediaItem = {
  type: 'image' | 'video' | 'gif';
  src: string;
  alt: string;
  poster?: string;
};

interface ContactData {
  title: string;
  subtitle: string;
  microcopy?: string;
  whatsappLabel: string;
  mapsLabel: string;
  backgroundMedia?: MediaItem | null;
}

interface SettingsData {
  whatsapp: { number: string; defaultMessage: string };
  address: { mapsUrl: string };
}

interface Props {
  contact: ContactData;
  settings: SettingsData;
  whatsappUrl: string;
}

const { contact, settings, whatsappUrl } = Astro.props;
const hasBg = contact.backgroundMedia != null;
---

<section id="contacto" class="relative section-pad bg-depth-primary text-white overflow-hidden">

  <!-- Background media layer (optional) -->
  {hasBg && contact.backgroundMedia?.type === 'image' && (
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <img
        src={contact.backgroundMedia.src}
        alt=""
        class="w-full h-full object-cover opacity-15 mix-blend-luminosity"
        loading="lazy"
        decoding="async"
      />
      <div class="absolute inset-0 bg-primary/70"></div>
    </div>
  )}

  <!-- Decorative spring background (always visible) -->
  <div class="absolute inset-0 spring-bg opacity-[0.12] pointer-events-none" aria-hidden="true"></div>

  <div class="container-jc relative z-10">
    <div class="max-w-2xl mx-auto text-center flex flex-col items-center gap-8">

      <!-- Spring accent -->
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 80 12" width="80" height="12" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round" class="opacity-30" aria-hidden="true">
        <path d="M0 6 C5 0, 10 12, 15 6 C20 0, 25 12, 30 6 C35 0, 40 12, 45 6 C50 0, 55 12, 60 6 C65 0, 70 12, 75 6 C77 4, 79 6, 80 6"/>
      </svg>

      <h2 class="font-heading text-h2 font-bold uppercase leading-tight text-white">
        {contact.title}
      </h2>

      <p class="text-subtitle text-white/80 leading-relaxed">
        {contact.subtitle}
      </p>

      <div class="flex flex-wrap gap-4 justify-center">
        <Button href={whatsappUrl} variant="whatsapp" size="lg" external>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          {contact.whatsappLabel}
        </Button>

        <Button href={settings.address.mapsUrl} variant="outline-white" size="lg" external>
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
            <circle cx="12" cy="10" r="3"/>
          </svg>
          {contact.mapsLabel}
        </Button>
      </div>

      {contact.microcopy && (
        <p class="text-[0.8125rem] text-white/50 italic">
          {contact.microcopy}
        </p>
      )}

    </div>
  </div>
</section>
