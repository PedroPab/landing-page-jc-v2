---
import { Image } from 'astro:assets';
import { resolveImage } from '@/lib/images';
import SectionHeading from "@/components/ui/SectionHeading.astro";
import SpringDivider from "@/components/ui/SpringDivider.astro";

interface ClientLogo {
  type: string;
  src: string;
  alt: string;
}

interface ClientItem {
  id: string;
  name: string;
  sector: string;
  description?: string;
  logo?: ClientLogo | null;
}

interface ClientsData {
  title: string;
  subtitle?: string;
  items: ClientItem[];
}

interface Props {
  data: ClientsData;
}

const { data } = Astro.props;

const clients = data.items ?? [];
const loopClients = [...clients, ...clients];
const autoSpeed = 500;
---

<section id="clientes" class="section-pad bg-surface">
  <div class="container-jc mb-10 md:mb-12">
    <SectionHeading
      eyebrow="Clientes"
      title={data.title}
      subtitle={data.subtitle}
      align="center"
    />
    <SpringDivider width={80} coils={6} class="mt-5 mx-auto" />
  </div>

  {
    clients.length > 0 && (
      <div
        class="jc-clients-strip"
        aria-label="Empresas clientes de JC Resortes"
        data-clients-carousel
        style={`--jc-auto-speed: ${autoSpeed};`}
      >
        <div class="jc-clients-viewport" data-clients-viewport tabindex="0">
          <div class="jc-clients-track" data-clients-track>
            {loopClients.map((client, i) => {
              const isClone = i >= clients.length;

              return (
                <figure class="jc-client-item" aria-hidden={isClone}>
                  <div class="jc-client-logo-wrap">
                    {client.logo?.src ? (
                      <>
                        {resolveImage(client.logo.src) ? (
                          <Image
                            src={resolveImage(client.logo.src)!}
                            alt={isClone ? "" : client.logo.alt}
                            class="jc-client-logo"
                            loading={i < clients.length ? "eager" : "lazy"}
                            draggable="false"
                            onerror="this.hidden=true;this.nextElementSibling.hidden=false"
                          />
                        ) : (
                          <img
                            src={client.logo.src}
                            alt={isClone ? "" : client.logo.alt}
                            class="jc-client-logo"
                            loading={i < clients.length ? "eager" : "lazy"}
                            decoding="async"
                            draggable="false"
                            onerror="this.hidden=true;this.nextElementSibling.hidden=false"
                          />
                        )}
                        <span
                          class="jc-client-initial"
                          hidden
                          aria-hidden={isClone}
                        >
                          {client.name.charAt(0)}
                        </span>
                      </>
                    ) : (
                      <span class="jc-client-initial" aria-hidden={isClone}>
                        {client.name.charAt(0)}
                      </span>
                    )}
                  </div>

                  <figcaption class="jc-client-name" aria-hidden={isClone}>
                    {client.name}
                  </figcaption>
                </figure>
              );
            })}
          </div>
        </div>
      </div>
    )
  }
</section>

<style is:global>
  .jc-clients-strip {
    --jc-surface: var(--color-surface, #f7f7f5);

    position: relative;
    width: 100%;
    padding-block: clamp(1rem, 2vw, 1.75rem);
  }

  .jc-clients-strip::before,
  .jc-clients-strip::after {
    content: "";
    position: absolute;
    top: 0;
    bottom: 0;
    width: clamp(2.5rem, 9vw, 8rem);
    z-index: 2;
    pointer-events: none;
  }

  .jc-clients-strip::before {
    left: 0;
    background: linear-gradient(to right, var(--jc-surface), transparent);
  }

  .jc-clients-strip::after {
    right: 0;
    background: linear-gradient(to left, var(--jc-surface), transparent);
  }

  .jc-clients-track {
    display: flex;
    align-items: center;
    width: max-content;
    gap: clamp(2.25rem, 5vw, 5.5rem);
    padding-inline: clamp(1.25rem, 3vw, 2.5rem);
    will-change: scroll-position;
  }

  .jc-clients-viewport {
    overflow-x: auto;
    overflow-y: hidden;
    scroll-behavior: smooth;
    cursor: grab;
    user-select: none;
    scrollbar-width: none;
    -ms-overflow-style: none;
    touch-action: pan-x;
  }

  .jc-clients-viewport::-webkit-scrollbar {
    display: none;
  }

  .jc-clients-viewport.is-dragging {
    cursor: grabbing;
    scroll-behavior: auto;
  }

  .jc-client-item {
    width: clamp(12rem, 20vw, 17rem);
    min-width: clamp(12rem, 20vw, 17rem);
    margin: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;

    /*
      Importante:
      Esto evita que en móvil se vuelva cuadrícula.
    */
    flex-shrink: 0;
  }

  .jc-client-logo-wrap {
    height: clamp(6rem, 12vw, 9rem);
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .jc-client-logo {
    display: block;
    max-width: 100%;
    max-height: clamp(5rem, 11vw, 8rem);
    object-fit: contain;
    opacity: 1;
    transition:
      opacity 0.25s ease,
      transform 0.25s ease;
  }

  .jc-client-name {
    margin-top: 0.65rem;
    font-family: var(--font-heading);
    font-size: clamp(0.7rem, 1.3vw, 0.8rem);
    font-weight: 700;
    line-height: 1.2;
    text-align: center;
    color: var(--color-foreground, #151515);
    opacity: 0.78;
  }

  .jc-client-initial {
    width: 3rem;
    height: 3rem;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading);
    font-weight: 700;
    color: var(--color-primary, #428c0d);
    background: var(--color-primary-soft, rgba(66, 140, 13, 0.12));
  }

  @media (hover: hover) and (pointer: fine) {
    .jc-client-item:hover .jc-client-logo {
      transform: scale(1.06);
    }

    .jc-client-item:hover .jc-client-name {
      opacity: 1;
    }
  }

  @media (max-width: 640px) {
    .jc-clients-strip {
      padding-block: 1rem;
    }

    .jc-clients-track {
      gap: 2.5rem;
      padding-inline: 1.25rem;
    }

    .jc-client-item {
      width: 11rem;
      min-width: 11rem;
    }

    .jc-client-logo-wrap {
      height: 6rem;
    }

    .jc-client-logo {
      max-height: 5rem;
    }

    .jc-client-name {
      font-size: 0.72rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .jc-clients-viewport {
      scroll-behavior: auto;
    }
  }
</style>

<script>
  const carousels = document.querySelectorAll("[data-clients-carousel]");

  carousels.forEach((carousel) => {
    const viewport = carousel.querySelector("[data-clients-viewport]");
    const track = carousel.querySelector("[data-clients-track]");

    if (!(viewport instanceof HTMLElement) || !(track instanceof HTMLElement)) {
      return;
    }

    const prefersReducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;

    let animationFrame = 0;
    let dragging = false;
    let paused = false;
    let startX = 0;
    let startScrollLeft = 0;
    let resumeTimer = 0;
    let lastTimestamp = 0;

    const getLoopWidth = () => track.scrollWidth / 2;
    const getSpeed = () =>
      Number.parseFloat(
        getComputedStyle(carousel).getPropertyValue("--jc-auto-speed"),
      ) || 20;

    const normalizeScroll = () => {
      const loopWidth = getLoopWidth();

      if (!loopWidth) return;

      if (viewport.scrollLeft >= loopWidth) {
        viewport.scrollLeft -= loopWidth;
      } else if (viewport.scrollLeft <= 0) {
        viewport.scrollLeft += loopWidth;
      }
    };

    const pauseTemporarily = (delay = 1800) => {
      paused = true;
      window.clearTimeout(resumeTimer);
      resumeTimer = window.setTimeout(() => {
        paused = false;
      }, delay);
    };

    const tick = (timestamp) => {
      if (!lastTimestamp) lastTimestamp = timestamp;

      const delta = timestamp - lastTimestamp;
      lastTimestamp = timestamp;

      if (!paused && !dragging && !prefersReducedMotion) {
        viewport.scrollLeft += (delta / 1000) * getSpeed();
        normalizeScroll();
      }

      animationFrame = window.requestAnimationFrame(tick);
    };

    const startDrag = (clientX) => {
      dragging = true;
      paused = true;
      startX = clientX;
      startScrollLeft = viewport.scrollLeft;
      viewport.classList.add("is-dragging");
    };

    const moveDrag = (clientX) => {
      if (!dragging) return;

      const delta = clientX - startX;
      viewport.scrollLeft = startScrollLeft - delta;
      normalizeScroll();
    };

    const endDrag = () => {
      if (!dragging) return;

      dragging = false;
      viewport.classList.remove("is-dragging");
      pauseTemporarily();
    };

    const initializePosition = () => {
      const loopWidth = getLoopWidth();

      if (!loopWidth) return;

      viewport.scrollLeft = Math.min(loopWidth, viewport.scrollWidth);
    };

    initializePosition();

    viewport.addEventListener("pointerdown", (event) => {
      startDrag(event.clientX);
      viewport.setPointerCapture(event.pointerId);
    });

    viewport.addEventListener("pointermove", (event) => {
      moveDrag(event.clientX);
    });

    viewport.addEventListener("pointerup", endDrag);
    viewport.addEventListener("pointercancel", endDrag);
    viewport.addEventListener("pointerleave", endDrag);

    viewport.addEventListener("focusin", () => {
      pauseTemporarily(1200);
    });

    viewport.addEventListener(
      "wheel",
      (event) => {
        if (Math.abs(event.deltaY) <= Math.abs(event.deltaX)) return;

        event.preventDefault();
        viewport.scrollLeft += event.deltaY;
        normalizeScroll();
        pauseTemporarily();
      },
      { passive: false },
    );

    viewport.addEventListener("keydown", (event) => {
      if (event.key !== "ArrowLeft" && event.key !== "ArrowRight") return;

      event.preventDefault();
      const direction = event.key === "ArrowRight" ? 1 : -1;
      viewport.scrollLeft += direction * 180;
      normalizeScroll();
      pauseTemporarily();
    });

    animationFrame = window.requestAnimationFrame(tick);

    window.addEventListener("resize", () => {
      normalizeScroll();
      if (viewport.scrollLeft <= 0) {
        initializePosition();
      }
    });
    window.addEventListener("beforeunload", () => {
      window.cancelAnimationFrame(animationFrame);
      window.clearTimeout(resumeTimer);
    });
  });
</script>
