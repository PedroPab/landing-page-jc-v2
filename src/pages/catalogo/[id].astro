---
import BaseLayout from "@/layouts/BaseLayout.astro";
import {
  getHomePageData,
  getProductsData,
  buildWhatsAppUrl,
} from "@/lib/content";

import Header from "@/components/sections/Header.astro";
import PageHero from "@/components/ui/PageHero.astro";
import SpringProductViewer from "@/components/ui/SpringProductViewer.astro";
import SpringDivider from "@/components/ui/SpringDivider.astro";
import Button from "@/components/ui/Button.astro";
import CtaContact from "@/components/sections/CtaContact.astro";
import Footer from "@/components/sections/Footer.astro";

export async function getStaticPaths() {
  const data = await getProductsData();
  return data.items.map((item) => ({
    params: { id: item.id },
    props: { product: item, allProducts: data.items },
  }));
}

interface MediaItem {
  type: string;
  src: string;
  alt: string;
  caption?: string;
  poster?: string;
}

interface ProductItem {
  id: string;
  name: string;
  description: string;
  applications: string[];
  materials: string[];
  finishes?: string[];
  notes?: string;
  photos?: MediaItem[];
}

interface Props {
  product: ProductItem;
  allProducts: ProductItem[];
}

const { product, allProducts } = Astro.props;
const { settings, contact } = await getHomePageData();

const whatsappMessage = `Hola, quiero solicitar una solución para ${product.name.toLowerCase()}`;
const whatsappUrl = buildWhatsAppUrl(settings.whatsapp.number, whatsappMessage);

// Related products: all except current
const related = allProducts.filter((p) => p.id !== product.id);

const siteUrl = settings.seo.siteUrl;
const productUrl = `${siteUrl}/catalogo/${product.id}`;

// Schema.org — Product
const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: product.name,
  description: product.description,
  url: productUrl,
  brand: {
    '@type': 'Brand',
    name: 'JC Resortes',
  },
  manufacturer: {
    '@type': 'Organization',
    '@id': `${siteUrl}/#business`,
    name: 'JC Resortes',
    url: siteUrl,
  },
  material: product.materials.join(', '),
  countryOfOrigin: 'CO',
  offers: {
    '@type': 'Offer',
    priceCurrency: 'COP',
    availability: 'https://schema.org/InStock',
    areaServed: 'CO',
    seller: {
      '@type': 'Organization',
      '@id': `${siteUrl}/#business`,
      name: 'JC Resortes',
    },
  },
};

// Schema.org — BreadcrumbList
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio',   item: siteUrl },
    { '@type': 'ListItem', position: 2, name: 'Catálogo', item: `${siteUrl}/catalogo` },
    { '@type': 'ListItem', position: 3, name: product.name, item: productUrl },
  ],
};
---

<BaseLayout
  title={`${product.name} — Resortes Industriales a la Medida | JC Resortes Medellín`}
  description={`${product.description} Fabricados a medida en Medellín, Colombia desde 1999. Solicita cotización por WhatsApp.`}
  additionalSchemas={[productSchema, breadcrumbSchema]}
>
  <Header settings={settings} whatsappUrl={whatsappUrl} />

  <main>
    <PageHero
      title={product.name}
      breadcrumbs={[
        { label: "Catálogo", href: "/catalogo" },
        { label: product.name },
      ]}
    />

    <!-- Product detail: 3D viewer + specs -->
    <section class="section-pad bg-surface">
      <div class="container-jc">
        <div
          class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-start"
        >
          <!-- Left: visor principal + strip de miniaturas -->
          <div class="flex flex-col gap-3 lg:sticky lg:top-8">

            <!-- Área principal: canvas 3D + overlay de foto -->
            <div class="relative" id={`main-${product.id}`}>
              <SpringProductViewer
                productId={product.id}
                label={`Visor 3D — ${product.name}`}
                title={product.name}
              />

              <!-- Overlay de foto — se muestra sobre el canvas al seleccionar una miniatura -->
              {product.photos && product.photos.length > 0 && (
                <div
                  id={`overlay-${product.id}`}
                  class="absolute inset-0 rounded-3xl overflow-hidden bg-white flex items-center justify-center opacity-0 pointer-events-none transition-opacity duration-300"
                  aria-hidden="true"
                >
                  <img
                    id={`overlay-img-${product.id}`}
                    src=""
                    alt=""
                    class="w-full h-full object-contain select-none"
                    draggable="false"
                  />
                </div>
              )}
            </div>

            <!-- Strip de miniaturas (3D + fotos) -->
            {product.photos && product.photos.length > 0 && (
              <div
                class="jc-thumb-strip flex gap-2 overflow-x-auto py-1 px-0.5"
                role="list"
                aria-label="Seleccionar vista del producto"
              >
                <!-- Miniatura del modelo 3D — activa por defecto -->
                <button
                  type="button"
                  role="listitem"
                  class="jc-thumb jc-thumb-active shrink-0 w-[4.5rem] h-[4.5rem] rounded-xl overflow-hidden relative border-2 border-muted bg-[#0e160b] outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2"
                  aria-label="Ver modelo 3D"
                  aria-pressed="true"
                  data-for={product.id}
                  data-type="3d"
                >
                  <div class="absolute inset-0 flex flex-col items-center justify-center gap-1.5 px-2">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 40 16"
                      width="38" height="15"
                      fill="none"
                      stroke="#428c0d"
                      stroke-width="1.8"
                      stroke-linecap="round"
                      aria-hidden="true"
                    >
                      <path d="M0 8 C3 0,7 16,10 8 C13 0,17 16,20 8 C23 0,27 16,30 8 C33 0,37 16,40 8"/>
                    </svg>
                    <span class="text-[0.5rem] text-white/40 font-heading uppercase tracking-widest leading-none">3D</span>
                  </div>
                </button>

                <!-- Miniaturas de fotos -->
                {product.photos.map((photo, i) => (
                  <button
                    type="button"
                    role="listitem"
                    class="jc-thumb shrink-0 w-[4.5rem] h-[4.5rem] rounded-xl overflow-hidden relative group border-2 border-muted outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 transition-[border-color] duration-150"
                    aria-label={`Vista ${i + 1}: ${photo.alt}`}
                    aria-pressed="false"
                    data-for={product.id}
                    data-type="photo"
                    data-src={photo.src}
                    data-alt={photo.alt}
                  >
                    <img
                      src={photo.src}
                      alt=""
                      class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-[1.08]"
                      loading="lazy"
                      decoding="async"
                    />
                  </button>
                ))}
              </div>
            )}
          </div>

          <!-- Right: Specs -->
          <div class="flex flex-col gap-8">
            <!-- Name + divider -->
            <div>
              <h2
                class="font-heading text-h2 font-bold uppercase leading-tight text-foreground mb-4"
              >
                {product.name}
              </h2>
              <SpringDivider width={80} coils={6} class="opacity-40" />
            </div>

            <!-- Description -->
            <p class="text-subtitle text-neutral leading-relaxed">
              {product.description}
            </p>

            <!-- Applications -->
            <div>
              <h3
                class="font-heading text-[0.6875rem] font-bold uppercase tracking-wider text-primary mb-3"
              >
                Aplicaciones
              </h3>
              <ul class="space-y-2">
                {
                  product.applications.map((app) => (
                    <li class="flex items-start gap-2 text-[0.9375rem] text-foreground/80">
                      <span
                        class="mt-2 shrink-0 w-1.5 h-1.5 rounded-full bg-primary"
                        aria-hidden="true"
                      />
                      {app}
                    </li>
                  ))
                }
              </ul>
            </div>

            <!-- Materials -->
            <div>
              <h3
                class="font-heading text-[0.6875rem] font-bold uppercase tracking-wider text-primary mb-3"
              >
                Materiales disponibles
              </h3>
              <ul class="space-y-2">
                {
                  product.materials.map((mat) => (
                    <li class="flex items-start gap-2 text-[0.9375rem] text-foreground/80">
                      <span
                        class="mt-2 shrink-0 w-1.5 h-1.5 rounded-full bg-primary/60"
                        aria-hidden="true"
                      />
                      {mat}
                    </li>
                  ))
                }
              </ul>
            </div>

            <!-- Finishes -->
            {product.finishes && product.finishes.length > 0 && (
              <div>
                <h3
                  class="font-heading text-[0.6875rem] font-bold uppercase tracking-wider text-primary mb-3"
                >
                  Acabados disponibles
                </h3>
                <ul class="space-y-2">
                  {
                    product.finishes.map((finish) => (
                      <li class="flex items-start gap-2 text-[0.9375rem] text-foreground/80">
                        <span
                          class="mt-2 shrink-0 w-1.5 h-1.5 rounded-full bg-primary/40"
                          aria-hidden="true"
                        />
                        {finish}
                      </li>
                    ))
                  }
                </ul>
              </div>
            )}

            <!-- Notes -->
            {
              product.notes && (
                <div class="border-t border-muted pt-6">
                  <p class="text-[0.875rem] text-neutral/80 leading-relaxed italic">
                    {product.notes}
                  </p>
                </div>
              )
            }

            <!-- CTA -->
            <div class="pt-2">
              <Button href={whatsappUrl} variant="whatsapp" size="lg" external>
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  width="16"
                  height="16"
                  fill="currentColor"
                  aria-hidden="true"
                >
                  <path
                    d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
                  ></path>
                </svg>
                Solicitar solución
              </Button>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Related products -->
    <section class="section-pad bg-surface border-t border-muted">
      <div class="container-jc">
        <h2
          class="font-heading text-[0.75rem] font-bold uppercase tracking-widest text-primary mb-2"
        >
          Otros productos
        </h2>
        <p
          class="font-heading text-h3 font-bold uppercase text-foreground mb-8"
        >
          Catálogo completo
        </p>

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-5">
          {
            related.map((rel) => (
              <a
                href={`/catalogo/${rel.id}`}
                class="group flex flex-col gap-3 bg-surface border border-muted rounded-lg p-6 relative overflow-hidden hover:border-primary/40 hover:shadow-card transition-all duration-300"
              >
                <div
                  class="absolute left-0 top-0 bottom-0 w-1 bg-primary/60 group-hover:bg-primary rounded-l-lg transition-colors duration-200"
                  aria-hidden="true"
                />
                <h3 class="font-heading text-[0.8125rem] font-bold uppercase tracking-wide text-foreground group-hover:text-primary transition-colors duration-200">
                  {rel.name}
                </h3>
                <p class="text-[0.8125rem] text-neutral leading-relaxed flex-1 line-clamp-2">
                  {rel.description}
                </p>
                <span class="text-[0.75rem] font-heading font-bold uppercase tracking-wide text-primary/70 group-hover:text-primary transition-colors duration-200">
                  Ver ficha →
                </span>
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <CtaContact
      contact={contact}
      settings={settings}
      whatsappUrl={whatsappUrl}
    />
  </main>

  <Footer settings={settings} whatsappUrl={whatsappUrl} />
</BaseLayout>

<!-- ── Estilos del visor con miniaturas ─────────────────────── -->
<style is:global>
  /* Miniatura activa: borde primary */
  .jc-thumb-active {
    border-color: var(--color-primary) !important;
    box-shadow: 0 0 0 2px var(--color-primary);
  }

  /* Ocultar scrollbar del strip manteniendo el scroll funcional */
  .jc-thumb-strip {
    scrollbar-width: none;
  }
  .jc-thumb-strip::-webkit-scrollbar {
    display: none;
  }
</style>

<!-- ── Script de interacción: cambio entre 3D y fotos ──────── -->
<script is:inline define:vars={{ productId: product.id, productPhotos: product.photos ?? [] }}>
  (function () {
    if (!productPhotos || productPhotos.length === 0) return;

    var overlay    = document.getElementById('overlay-' + productId);
    var overlayImg = document.getElementById('overlay-img-' + productId);
    var thumbs     = document.querySelectorAll('.jc-thumb[data-for="' + productId + '"]');

    function setActive(activeBtn) {
      thumbs.forEach(function (t) {
        t.classList.remove('jc-thumb-active');
        t.setAttribute('aria-pressed', 'false');
      });
      activeBtn.classList.add('jc-thumb-active');
      activeBtn.setAttribute('aria-pressed', 'true');
    }

    thumbs.forEach(function (thumb) {
      thumb.addEventListener('click', function () {
        setActive(thumb);

        if (thumb.dataset.type === '3d') {
          // ── Volver al canvas 3D
          if (overlay) {
            overlay.classList.add('opacity-0', 'pointer-events-none');
            overlay.setAttribute('aria-hidden', 'true');
          }
        } else {
          // ── Mostrar foto sobre el canvas
          var src = thumb.dataset.src;
          var alt = thumb.dataset.alt || '';
          if (overlay && overlayImg && src) {
            overlayImg.src = src;
            overlayImg.alt = alt;
            overlay.classList.remove('opacity-0', 'pointer-events-none');
            overlay.setAttribute('aria-hidden', 'false');
          }
        }
      });
    });
  })();
</script>
