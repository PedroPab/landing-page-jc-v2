---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getHomePageData, getProductsData, buildWhatsAppUrl } from '@/lib/content';

import Header      from '@/components/sections/Header.astro';
import PageHero    from '@/components/ui/PageHero.astro';
import ProductCard       from '@/components/ui/ProductCard.astro';
import ConfiguratorCard  from '@/components/ui/ConfiguratorCard.astro';
import CtaContact        from '@/components/sections/CtaContact.astro';
import Footer      from '@/components/sections/Footer.astro';

const { settings, contact } = await getHomePageData();
const productsData = await getProductsData();
const whatsappUrl  = buildWhatsAppUrl(settings.whatsapp.number, settings.whatsapp.defaultMessage);
---

<BaseLayout
  title="Catálogo de productos — JC Resortes | Resortes industriales a la medida"
  description="Catálogo completo de resortes industriales: compresión, tensión, torsión y gran escala. Fabricados a medida en Medellín, Colombia."
>
  <Header settings={settings} whatsappUrl={whatsappUrl} />

  <main>
    <PageHero
      title={productsData.title}
      subtitle={productsData.subtitle}
      breadcrumbs={[{ label: 'Catálogo' }]}
    />

    <section class="section-pad bg-surface">
      <div class="container-jc">

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          {productsData.items.map((item) => (
            <ProductCard
              productId={item.id}
              name={item.name}
              description={item.description}
              applications={item.applications}
              href={`/catalogo/${item.id}`}
            />
          ))}
          <ConfiguratorCard />
        </div>

      </div>
    </section>

    <CtaContact contact={contact} settings={settings} whatsappUrl={whatsappUrl} />
  </main>

  <Footer settings={settings} whatsappUrl={whatsappUrl} />
</BaseLayout>
