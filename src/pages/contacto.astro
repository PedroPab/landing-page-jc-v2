---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getHomePageData, buildWhatsAppUrl } from "@/lib/content";

import Header from "@/components/sections/Header.astro";
import PageHero from "@/components/ui/PageHero.astro";
import CtaContact from "@/components/sections/CtaContact.astro";
import Footer from "@/components/sections/Footer.astro";
import Button from "@/components/ui/Button.astro";
import SpringDivider from "@/components/ui/SpringDivider.astro";

const { settings, contact } = await getHomePageData();
const whatsappUrl = buildWhatsAppUrl(
  settings.whatsapp.number,
  settings.whatsapp.defaultMessage,
);

const mailtoUrl = settings.email
  ? `mailto:${settings.email}?subject=Cotización%20resortes%20industriales%20—%20JC%20Resortes&body=Hola%2C%20me%20interesa%20cotizar%20resortes%20industriales.%0A%0AMi%20nombre%20es%3A%20%0ATeléfono%3A%20%0ADescripción%20del%20resorte%20%2F%20necesidad%3A%20`
  : null;
---

<BaseLayout
  title="Contacto — JC Resortes | Solicitar información sobre resortes industriales"
  description="Contáctanos por WhatsApp o visítanos en Medellín. Empresa familiar especializada en resortes industriales a la medida. Atención directa y ágil."
>
  <Header settings={settings} whatsappUrl={whatsappUrl} />

  <main>
    <PageHero
      title="Contacto"
      subtitle="Cuéntanos tu necesidad y conversemos sobre la mejor forma de resolverla."
      breadcrumbs={[{ label: "Contacto" }]}
    />

    <!-- Contact detail block -->
    <section class="section-pad bg-white">
      <div class="container-jc">
        <!-- Intro -->
        <div class="mb-10 flex flex-col gap-3 max-w-xl">
          <p
            class="font-heading text-[0.7rem] uppercase tracking-widest text-primary font-bold"
          >
            Canales de contacto
          </p>
          <h2
            class="font-heading text-h3 font-bold uppercase text-foreground leading-tight"
          >
            Contáctanos directamente
          </h2>
          <p class="text-[0.875rem] text-neutral leading-relaxed">
            Atención sin intermediarios. Respondemos por WhatsApp en minutos o
            por correo si prefieres adjuntar especificaciones técnicas.
          </p>
        </div>

        <SpringDivider width={60} coils={5} class="mb-10" />

        <!-- Cards grid: 2 action cards + 2 info cards -->
        <div class="grid sm:grid-cols-2 gap-6 max-w-4xl">
          <!-- WhatsApp -->
          <article
            class="flex flex-col gap-5 bg-surface border border-muted rounded-lg p-6 border-l-4 border-l-[#25D366] hover:shadow-elevated transition-shadow"
          >
            <div class="flex items-start gap-4">
              <div
                class="w-10 h-10 shrink-0 rounded bg-[#25D366]/10 flex items-center justify-center"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  width="20"
                  height="20"
                  fill="#25D366"
                  aria-hidden="true"
                >
                  <path
                    d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
                  ></path>
                </svg>
              </div>
              <div>
                <p
                  class="font-heading text-[0.65rem] uppercase tracking-widest text-neutral font-bold mb-0.5"
                >
                  Respuesta inmediata
                </p>
                <h3
                  class="font-heading text-[0.875rem] font-bold uppercase tracking-wide text-foreground"
                >
                  WhatsApp
                </h3>
              </div>
            </div>

            <p class="text-[0.8125rem] text-neutral leading-relaxed flex-1">
              Canal directo con el equipo técnico. La forma más rápida de
              cotizar y resolver dudas en horario de atención.
            </p>

            {
              settings.phone && (
                <a
                  href={`tel:${settings.phone}`}
                  class="inline-flex items-center gap-2 text-[0.9375rem] font-semibold text-foreground hover:text-[#25D366] transition-colors"
                >
                  {settings.phone}
                </a>
              )
            }

            <Button href={whatsappUrl} variant="whatsapp" size="sm" external>
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                width="14"
                height="14"
                fill="currentColor"
                aria-hidden="true"
              >
                <path
                  d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
                ></path>
              </svg>
              Escribir ahora
            </Button>
          </article>

          <!-- Email -->
          {
            mailtoUrl && (
              <article class="flex flex-col gap-5 bg-surface border border-muted rounded-lg p-6 border-l-4 border-l-primary hover:shadow-elevated transition-shadow">
                <div class="flex items-start gap-4">
                  <div class="w-10 h-10 shrink-0 rounded bg-primary/10 flex items-center justify-center">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="20"
                      height="20"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      class="text-primary"
                      aria-hidden="true"
                    >
                      <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                      <polyline points="22,6 12,12 2,6" />
                    </svg>
                  </div>
                  <div>
                    <p class="font-heading text-[0.65rem] uppercase tracking-widest text-neutral font-bold mb-0.5">
                      Cotizaciones detalladas
                    </p>
                    <h3 class="font-heading text-[0.875rem] font-bold uppercase tracking-wide text-foreground">
                      Correo electrónico
                    </h3>
                  </div>
                </div>

                <p class="text-[0.8125rem] text-neutral leading-relaxed flex-1">
                  Ideal para enviar planos, medidas o especificaciones técnicas.
                  Respondemos con propuesta formal.
                </p>

                {settings.email && (
                  <a
                    href={`mailto:${settings.email}`}
                    class="inline-flex items-center gap-2 text-[0.9375rem] font-semibold text-foreground hover:text-primary transition-colors break-all"
                  >
                    {settings.email}
                  </a>
                )}

                <Button href={mailtoUrl} variant="outline" size="sm">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="14"
                    height="14"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                    <polyline points="22,6 12,12 2,6" />
                  </svg>
                  Enviar correo
                </Button>
              </article>
            )
          }

          <!-- Ubicación -->
          <article
            class="flex flex-col gap-5 bg-white border border-muted rounded-lg p-6 hover:shadow-card transition-shadow"
          >
            <div class="flex items-start gap-4">
              <div
                class="w-10 h-10 shrink-0 rounded bg-primary/10 flex items-center justify-center"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="text-primary"
                  aria-hidden="true"
                >
                  <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"
                  ></path>
                  <circle cx="12" cy="10" r="3"></circle>
                </svg>
              </div>
              <div>
                <p
                  class="font-heading text-[0.65rem] uppercase tracking-widest text-neutral font-bold mb-0.5"
                >
                  Medellín, Antioquia
                </p>
                <h3
                  class="font-heading text-[0.875rem] font-bold uppercase tracking-wide text-foreground"
                >
                  Ubicación
                </h3>
              </div>
            </div>

            <address
              class="not-italic flex flex-col gap-0.5 text-[0.8125rem] text-neutral leading-relaxed flex-1"
            >
              <span class="text-foreground font-medium"
                >{settings.address.street}</span
              >
              <span>Barrio Castilla</span>
              <span
                >{settings.address.city}, {
                  settings.address.region ?? "Antioquia"
                }</span
              >
              <span>{settings.address.country}</span>
            </address>

            <Button
              href={settings.address.mapsUrl}
              variant="outline"
              size="sm"
              external
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                <circle cx="12" cy="10" r="3"></circle>
              </svg>
              Ver en Google Maps
            </Button>
          </article>

          <!-- Horario -->
          <article
            class="flex flex-col gap-5 bg-white border border-muted rounded-lg p-6"
          >
            <div class="flex items-start gap-4">
              <div
                class="w-10 h-10 shrink-0 rounded bg-surface border border-muted flex items-center justify-center"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="text-neutral"
                  aria-hidden="true"
                >
                  <circle cx="12" cy="12" r="10"></circle>
                  <polyline points="12 6 12 12 16 14"></polyline>
                </svg>
              </div>
              <div>
                <p
                  class="font-heading text-[0.65rem] uppercase tracking-widest text-neutral font-bold mb-0.5"
                >
                  Lunes a sábado
                </p>
                <h3
                  class="font-heading text-[0.875rem] font-bold uppercase tracking-wide text-foreground"
                >
                  Horario de atención
                </h3>
              </div>
            </div>

            <dl class="flex flex-col gap-2 flex-1">
              <div
                class="flex items-center justify-between gap-4 py-2 border-b border-muted"
              >
                <dt class="text-[0.8125rem] text-neutral">Lunes – viernes</dt>
                <dd
                  class="font-heading text-[0.8125rem] font-bold text-foreground"
                >
                  7:00 – 17:00
                </dd>
              </div>
              <div
                class="flex items-center justify-between gap-4 py-2 border-b border-muted"
              >
                <dt class="text-[0.8125rem] text-neutral">Sábados</dt>
                <dd
                  class="font-heading text-[0.8125rem] font-bold text-foreground"
                >
                  7:00 – 12:00
                </dd>
              </div>
              <div class="flex items-center justify-between gap-4 py-2">
                <dt class="text-[0.8125rem] text-muted">Domingos</dt>
                <dd class="text-[0.8125rem] text-muted">Cerrado</dd>
              </div>
            </dl>
          </article>
        </div>

        <SpringDivider width={80} coils={6} class="mt-12" />
      </div>
    </section>

    <CtaContact
      contact={contact}
      settings={settings}
      whatsappUrl={whatsappUrl}
    />
  </main>

  <Footer settings={settings} whatsappUrl={whatsappUrl} />
</BaseLayout>
