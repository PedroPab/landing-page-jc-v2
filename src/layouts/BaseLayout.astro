---
import { getEntry } from 'astro:content';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
  noindex?: boolean;
  /** JSON-LD adicional por página (FAQ, Product, BreadcrumbList, etc.) */
  additionalSchemas?: object[];
}

const settings = await getEntry('siteSettings', 'default');
if (!settings) throw new Error('siteSettings "default" not found');
const s = settings.data;

const {
  title = s.seo.defaultTitle,
  description = s.seo.defaultDescription,
  ogImage = s.seo.defaultImage,
  canonical,
  noindex = false,
  additionalSchemas = [],
} = Astro.props;

const siteUrl = s.seo.siteUrl;
const canonicalUrl = canonical
  ? new URL(canonical, siteUrl).href
  : new URL(Astro.url.pathname, siteUrl).href;
const ogImageUrl = ogImage.startsWith('http') ? ogImage : new URL(ogImage, siteUrl).href;

// Horario de atención para schema.org
const openingHours = s.businessHours?.map((h) => ({
  '@type': 'OpeningHoursSpecification',
  dayOfWeek: h.days.split(','),
  opens: h.opens,
  closes: h.closes,
})) ?? [];

// Schema.org — LocalBusiness + ManufacturingBusiness completo
const businessSchema = {
  '@context': 'https://schema.org',
  '@type': ['LocalBusiness', 'ManufacturingBusiness'],
  '@id': `${siteUrl}/#business`,
  name: s.name,
  legalName: s.legalName ?? s.name,
  alternateName: 'JC Resortes Medellín',
  identifier: s.nit ? { '@type': 'PropertyValue', name: 'NIT', value: s.nit } : undefined,
  description: s.seo.defaultDescription,
  url: siteUrl,
  telephone: s.phone ?? `+${s.whatsapp.number}`,
  email: s.email,
  logo: {
    '@type': 'ImageObject',
    url: `${siteUrl}/favicon.svg`,
    contentUrl: `${siteUrl}/favicon.svg`,
  },
  image: ogImageUrl,
  address: {
    '@type': 'PostalAddress',
    streetAddress: s.address.street,
    addressLocality: s.address.city,
    addressRegion: s.address.region ?? 'Antioquia',
    postalCode: s.address.postalCode ?? '050001',
    addressCountry: 'CO',
  },
  geo: s.geo
    ? {
        '@type': 'GeoCoordinates',
        latitude: s.geo.lat,
        longitude: s.geo.lng,
      }
    : undefined,
  hasMap: s.address.mapsUrl,
  openingHoursSpecification: openingHours,
  priceRange: '$$',
  currenciesAccepted: 'COP',
  paymentAccepted: 'Efectivo, Transferencia bancaria',
  areaServed: [
    { '@type': 'City',    name: 'Medellín' },
    { '@type': 'State',   name: 'Antioquia' },
    { '@type': 'Country', name: 'Colombia' },
  ],
  foundingDate: '1999',
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Catálogo de Resortes Industriales JC Resortes',
    itemListElement: [
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Resortes de Compresión a la Medida',     url: `${siteUrl}/catalogo` } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Resortes de Tensión a la Medida',        url: `${siteUrl}/catalogo` } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Resortes de Torsión a la Medida',        url: `${siteUrl}/catalogo` } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Tratamiento Térmico de Resortes',        url: `${siteUrl}/que-hacemos` } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Resortes y Piezas Especiales a Medida',  url: `${siteUrl}/catalogo` } },
    ],
  },
  knowsAbout: [
    'resortes industriales',
    'fabricación de resortes a la medida',
    'resortes de compresión',
    'resortes de tensión',
    'resortes de torsión',
    'tratamiento térmico de resortes',
    'soluciones metalmecánicas',
    'resortes para industria alimentaria',
    'resortes para minería',
    'resortes para motocicletas',
    'resortes industriales Medellín',
    'proveedor de resortes Colombia',
  ],
  sameAs: [
    s.address.mapsUrl,
    ...(s.reviewUrl ? [s.reviewUrl] : []),
  ].filter(Boolean),
};

// Keywords para meta tag
const keywords = s.seo.keywords?.join(', ') ?? '';
---

<!DOCTYPE html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="Content-Language" content="es" />

    <!-- Primary Meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    {keywords && <meta name="keywords" content={keywords} />}
    <meta name="author" content={s.name} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Robots -->
    {noindex
      ? <meta name="robots" content="noindex, nofollow" />
      : <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
    }

    <!-- Geo / Local SEO -->
    <meta name="geo.region" content="CO-ANT" />
    <meta name="geo.placename" content="Medellín, Antioquia, Colombia" />
    {s.geo && <meta name="geo.position" content={`${s.geo.lat};${s.geo.lng}`} />}
    {s.geo && <meta name="ICBM" content={`${s.geo.lat}, ${s.geo.lng}`} />}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={s.seo.locale} />
    <meta property="og:site_name" content={s.name} />

    <!-- Twitter / X Card -->
    <meta name="twitter:card" content="summary_large_image" />
    {s.seo.twitterSite && <meta name="twitter:site" content={s.seo.twitterSite} />}
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Sitemap -->
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Google Fonts — Montserrat (headings) + Inter (body) -->
    <!-- preconnect to reduce DNS + TLS handshake latency -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Non-blocking font load: media="print" trick avoids render-blocking -->
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@700;800&family=Inter:wght@400;500;600&display=swap"
    />
    <link
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@700;800&family=Inter:wght@400;500;600&display=swap"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Montserrat:wght@700;800&family=Inter:wght@400;500;600&display=swap"
      />
    </noscript>

    <!-- Schema.org JSON-LD — LocalBusiness / ManufacturingBusiness -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify(businessSchema)} />

    <!-- Schema.org JSON-LD adicional por página (FAQ, Product, BreadcrumbList…) -->
    {additionalSchemas.map((schema) => (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
  </head>
  <body class="bg-white text-foreground font-body antialiased">
    <slot />
  </body>
</html>
